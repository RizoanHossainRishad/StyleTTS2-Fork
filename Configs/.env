# =============================================================================
# Environment Variables — StyleTTS2 Finetune
# =============================================================================
# HOW TO USE:
#   Option 1 (recommended): source this file before running training
#     $ source .env
#     $ python train_second_stage.py -p Configs/config_ft.yml
#
#   Option 2: use python-dotenv (pip install python-dotenv)
#     Add this to the top of train_second_stage.py:
#       from dotenv import load_dotenv
#       load_dotenv()
#
# IMPORTANT: Add .env to your .gitignore so the API key is never committed.
#   $ echo ".env" >> .gitignore
# =============================================================================
 
